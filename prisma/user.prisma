model User {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String

    role   Role
    status UserStatus @default(ACTIVE)

    phone String?
    image String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    properties Property[]
    rentals    RentalRequest[]
    reviews    Review[]
}
